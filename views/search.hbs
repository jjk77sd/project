<div class="mt-5">

    <form action="/search" method="GET">

        <input
            type="text"
            name="q"
            value="{{keyword}}"
            placeholder="Nhập từ khóa..."
        >

        <button>Tìm kiếm</button>

    </form>
    {{#if keyword}}
        <h3>Kết quả: {{keyword}}</h3>
    {{/if}}

</div>